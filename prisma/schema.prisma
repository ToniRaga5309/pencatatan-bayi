// Skema database untuk Sistem Pencatatan Nama Bayi Baru Lahir
// Database: SQLite (Local Development)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tabel Puskesmas
model Puskesmas {
  id          String        @id @default(cuid())
  nama        String
  kodeWilayah String        @map("kode_wilayah")
  alamat      String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  users        User[]
  birthRecords BirthRecord[]

  @@map("puskesmas")
}

// Tabel User
model User {
  id          String    @id @default(cuid())
  username    String    @unique
  password    String
  namaLengkap String    @map("nama_lengkap")
  role        String
  isActive    Boolean   @default(true) @map("is_active")
  puskesmasId String?   @map("puskesmas_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  puskesmas       Puskesmas?    @relation(fields: [puskesmasId], references: [id], onDelete: SetNull)
  auditLogs       AuditLog[]
  createdRecords  BirthRecord[] @relation("CreatedBy")
  verifiedRecords BirthRecord[] @relation("VerifiedBy")

  @@index([username])
  @@map("users")
}

// Tabel BirthRecord
model BirthRecord {
  id              String     @id @default(cuid())
  nikIbu          String     @map("nik_ibu")
  namaIbu         String     @map("nama_ibu")
  namaAyah        String     @map("nama_ayah")
  namaBayi        String     @map("nama_bayi")
  tanggalLahir    DateTime   @map("tanggal_lahir")
  tempatLahir     String     @map("tempat_lahir")
  jenisKelamin    String     @map("jenis_kelamin")
  status          String     @default("VERIFIED")
  alasanPenolakan String?    @map("alasan_penolakan")
  isDeleted       Boolean    @default(false) @map("is_deleted")
  puskesmasId     String     @map("puskesmas_id")
  createdBy       String     @map("created_by")
  verifiedBy      String?    @map("verified_by")
  verifiedAt      DateTime?  @map("verified_at")
  downloadedAt    DateTime?  @map("downloaded_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  puskesmas  Puskesmas @relation(fields: [puskesmasId], references: [id], onDelete: Cascade)
  creator    User      @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  verifier   User?     @relation("VerifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)
  auditLogs  AuditLog[]

  @@index([puskesmasId])
  @@index([status])
  @@index([tanggalLahir])
  @@index([downloadedAt])
  @@map("birth_records")
}

// Tabel AuditLog
model AuditLog {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  action    String
  entity    String
  entityId  String?     @map("entity_id")
  details   String?
  ipAddress String?     @map("ip_address")
  userAgent String?     @map("user_agent")
  createdAt DateTime    @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthRecord BirthRecord? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
